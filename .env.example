# --- LLM provider selection -------------------------------------------------
# One of: mock | groq | openrouter | ollama
# "mock" needs no API key and is the zero-setup default for local dev/demo.
LLM_PROVIDER=mock

# Default model id (provider-specific). Examples:
#   groq:       llama-3.1-8b-instant
#   openrouter: meta-llama/llama-3.1-8b-instruct:free
#   ollama:     llama3.1
#   mock:       mock-llama-3.1-8b
LLM_MODEL=mock-llama-3.1-8b

# API keys (only needed for the matching provider)
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Base URLs (override only if needed)
GROQ_BASE_URL=https://api.groq.com/openai/v1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Service config ---------------------------------------------------------
DB_PATH=data/observability.db

# Request timeout (seconds) and retry policy for the LLM call
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# Store raw input/output in traces. Set to false to redact (data governance).
STORE_PROMPTS=true
